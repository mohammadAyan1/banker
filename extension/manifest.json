{
  "manifest_version": 3,
  "name": "JSON Auto-Fill Extension",
  "version": "1.0",
  "description": "Auto-fills forms using a JSON file.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}
